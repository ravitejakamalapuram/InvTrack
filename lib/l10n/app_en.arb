  "howToEnableDebugMode": "How do I enable debug mode?",
  "@howToEnableDebugMode": {
    "description": "FAQ question about enabling debug mode"
  },

  "howToEnableDebugModeAnswer": "Tap the version number on the About screen 7 times within 3 seconds. This will reveal developer tools in Settings.",
  "@howToEnableDebugModeAnswer": {
    "description": "FAQ answer about enabling debug mode"
  },

  "whatIsDebugModeFor": "What is debug mode for?",
  "@whatIsDebugModeFor": {
    "description": "FAQ question about debug mode purpose"
  },

  "whatIsDebugModeForAnswer": "Debug mode provides advanced tools for developers and power users, including sample data management and app diagnostics. It is useful for testing features and troubleshooting issues.",
  "@whatIsDebugModeForAnswer": {
    "description": "FAQ answer about debug mode purpose"
  },

  "howToDisableDebugMode": "How do I disable debug mode?",
  "@howToDisableDebugMode": {
    "description": "FAQ question about disabling debug mode"
  },

  "howToDisableDebugModeAnswer": "Tap the version number 7 times again, or toggle it off in Debug Settings under the Developer section in Settings.",
  "@howToDisableDebugModeAnswer": {
    "description": "FAQ answer about disabling debug mode"
