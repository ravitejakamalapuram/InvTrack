  "howToAddFirstInvestment": "How do I add my first investment?",
  "@howToAddFirstInvestment": {
    "description": "FAQ question"
  },

  "howToAddFirstInvestmentAnswer": "Tap the \"+\" button on the Investments tab. Enter your investment details including name, amount, date, and category. You can also add transactions later to track your investment growth.",
  "@howToAddFirstInvestmentAnswer": {
    "description": "FAQ answer"
  },

  "whatInvestmentTypesSupported": "What investment types are supported?",
  "@whatInvestmentTypesSupported": {
    "description": "FAQ question"
  },

  "whatInvestmentTypesSupportedAnswer": "InvTrack supports Stocks, Mutual Funds, Fixed Deposits, Gold, Real Estate, Crypto, and more. You can categorize any investment type.",
  "@whatInvestmentTypesSupportedAnswer": {
    "description": "FAQ answer"
  },

  "trackingReturns": "Tracking Returns",
  "@trackingReturns": {
    "description": "Tracking Returns section title"
  },

  "howAreReturnsCalculated": "How are returns calculated?",
  "@howAreReturnsCalculated": {
    "description": "FAQ question"
  },

  "howAreReturnsCalculatedAnswer": "InvTrack uses XIRR (Extended Internal Rate of Return) to calculate accurate returns considering all your transactions and their timing. This gives you a true picture of your investment performance.",
  "@howAreReturnsCalculatedAnswer": {
    "description": "FAQ answer"
  },

  "whatIsXirr": "What is XIRR?",
  "@whatIsXirr": {
    "description": "FAQ question"
  },

  "whatIsXirrAnswer": "XIRR is the industry-standard method for calculating returns on investments with multiple cash flows at different times. It accounts for when you invested and when you withdrew money.",
  "@whatIsXirrAnswer": {
    "description": "FAQ answer"
  },

  "goalsSection": "Goals",
  "@goalsSection": {
    "description": "Goals section title"
  },

  "howToSetFinancialGoal": "How do I set a financial goal?",
  "@howToSetFinancialGoal": {
    "description": "FAQ question"
  },

  "howToSetFinancialGoalAnswer": "Go to the Goals tab and tap \"+\". Enter your goal name, target amount, and deadline. InvTrack will track your progress and show how much you need to save.",
  "@howToSetFinancialGoalAnswer": {
    "description": "FAQ answer"
  },

  "canLinkInvestmentsToGoals": "Can I link investments to goals?",
  "@canLinkInvestmentsToGoals": {
    "description": "FAQ question"
  },

  "canLinkInvestmentsToGoalsAnswer": "Yes! When creating or editing a goal, you can allocate specific investments toward that goal. This helps you track progress toward multiple goals simultaneously.",
  "@canLinkInvestmentsToGoalsAnswer": {
    "description": "FAQ answer"
  },

  "privacyAndSecurity": "Privacy & Security",
  "@privacyAndSecurity": {
    "description": "Privacy & Security section title"
  },

  "isMyDataSecure": "Is my data secure?",
  "@isMyDataSecure": {
    "description": "FAQ question"
  },

  "isMyDataSecureAnswer": "Yes! All your data is stored securely in Firebase with encryption. You can also enable app lock with PIN or biometrics for extra security.",
  "@isMyDataSecureAnswer": {
    "description": "FAQ answer"
  },

  "whatIsPrivacyMode": "What is Privacy Mode?",
  "@whatIsPrivacyMode": {
    "description": "FAQ question"
  },

  "whatIsPrivacyModeAnswer": "Privacy Mode hides all financial amounts in the app, showing \"•••••\" instead. Perfect for when you want to check your portfolio in public. Toggle it from Settings → Appearance.",
  "@whatIsPrivacyModeAnswer": {
    "description": "FAQ answer"
  },

  "dataManagementSection": "Data Management",
  "@dataManagementSection": {
    "description": "Data Management section title"
  },

  "canExportMyData": "Can I export my data?",
  "@canExportMyData": {
    "description": "FAQ question"
  },

  "canExportMyDataAnswer": "Yes! Go to Settings → Data & Account → Export Data. You can download all your investment data as a ZIP file containing CSV files.",
  "@canExportMyDataAnswer": {
    "description": "FAQ answer"
  },

  "howToBackupData": "How do I backup my data?",
  "@howToBackupData": {
    "description": "FAQ question"
  },

  "howToBackupDataAnswer": "Your data is automatically backed up to Firebase when you''re signed in. You can also export a local backup anytime from Settings → Data & Account.",
  "@howToBackupDataAnswer": {
    "description": "FAQ answer"
  },

  "multiCurrencySupport": "Multi-Currency Support",
  "@multiCurrencySupport": {
    "description": "Multi-Currency Support section title"
  },

  "canChangeMyCurrency": "Can I change my currency?",
  "@canChangeMyCurrency": {
    "description": "FAQ question"
  },

  "canChangeMyCurrencyAnswer": "Yes! Go to Settings → Currency and select from 40+ supported currencies. The app will format all amounts according to your selected currency and locale.",
  "@canChangeMyCurrencyAnswer": {
    "description": "FAQ answer"
  },

  "howDoesCurrencyFormattingWork": "How does currency formatting work?",
  "@howDoesCurrencyFormattingWork": {
    "description": "FAQ question"
  },

  "howDoesCurrencyFormattingWorkAnswer": "InvTrack automatically formats numbers based on your currency:\n• Indian Rupee (₹): Shows 1L, 10L, 1Cr\n• USD/EUR/GBP: Shows 100K, 1M, 10M\n• Other currencies use appropriate locale formatting",
  "@howDoesCurrencyFormattingWorkAnswer": {
    "description": "FAQ answer"
  },

